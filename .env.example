# Optional: YouTube Data API v3 key for channel category enrichment.
# If unset, the app falls back to local keyword-based classification.
# Get one at: https://console.cloud.google.com/ → APIs & Services → Credentials
VITE_YOUTUBE_API_KEY=your_key_here

# ---------------------------------------------------------------------------
# Google AdSense
# ---------------------------------------------------------------------------
# Your AdSense publisher ID (begins with `ca-pub-`). Found in the AdSense
# console → Account → Settings → Account information.
# When set, src/components/AdBanner.jsx auto-injects the AdSense loader
# script and renders <ins class="adsbygoogle"> for each slot.
# Leave blank to keep the dev placeholder.
VITE_ADSENSE_CLIENT=

# Per-slot ad-unit IDs (10-digit numbers from the AdSense console).
# Optional — when missing, the slot prop name (e.g. "dashboard-top") is
# used as the data-ad-slot value. Set these once you've created the
# matching ad units in AdSense.
VITE_ADSENSE_SLOT_DASHBOARD_TOP=
VITE_ADSENSE_SLOT_DASHBOARD_BOTTOM=
VITE_ADSENSE_SLOT_ANALYSIS=

# Set to "true" while testing — adds data-adtest="on" so AdSense doesn't
# count impressions during development.
VITE_ADSENSE_TEST=false
